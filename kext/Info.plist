<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>English</string>

    <key>CFBundleExecutable</key>
    <string>VirtIOSerial</string>

    <key>CFBundleIdentifier</key>
    <string>com.github.mac-guest-agent.VirtIOSerial</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>VirtIO Serial Driver</string>

    <key>CFBundlePackageType</key>
    <string>KEXT</string>

    <key>CFBundleShortVersionString</key>
    <string>2.0.0</string>

    <key>CFBundleVersion</key>
    <string>2.0.0</string>

    <key>OSBundleRequired</key>
    <string>Root</string>

    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.kpi.bsd</key>
        <string>8.0</string>
        <key>com.apple.kpi.iokit</key>
        <string>8.0</string>
        <key>com.apple.kpi.libkern</key>
        <string>8.0</string>
        <key>com.apple.kpi.mach</key>
        <string>8.0</string>
        <key>com.apple.iokit.IOPCIFamily</key>
        <string>1.0</string>
    </dict>

    <key>IOKitPersonalities</key>
    <dict>
        <!-- Match VirtIO console/serial: legacy/transitional device -->
        <key>VirtIOSerial-Legacy</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.github.mac-guest-agent.VirtIOSerial</string>
            <key>IOClass</key>
            <string>VirtIOConsole</string>
            <key>IOProviderClass</key>
            <string>IOPCIDevice</string>
            <key>IOPCIPrimaryMatch</key>
            <string>0x10031af4</string>
            <key>IOProbeScore</key>
            <integer>5000</integer>
        </dict>

        <!-- Match VirtIO console/serial: modern device -->
        <key>VirtIOSerial-Modern</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.github.mac-guest-agent.VirtIOSerial</string>
            <key>IOClass</key>
            <string>VirtIOConsole</string>
            <key>IOProviderClass</key>
            <string>IOPCIDevice</string>
            <key>IOPCIPrimaryMatch</key>
            <string>0x10431af4</string>
            <key>IOProbeScore</key>
            <integer>5000</integer>
        </dict>
    </dict>
</dict>
</plist>
